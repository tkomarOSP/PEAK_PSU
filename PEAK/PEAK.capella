            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="5efb1749-742c-407a-896c-527d487df1c9"
                ReqIFName="Power Communications" ReqIFText="The communications system shall be powered through the kit. Rationale:For consistent operation and autonomy.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="5903c80d-5445-47d4-90d1-b39ee7f144ab" source="#5efb1749-742c-407a-896c-527d487df1c9"
