            <ownedRequirements xsi:type="Requirements:Requirement" id="c9f1f3cf-185b-4016-a2dd-b2b71050b8ed"
                ReqIFName="Wide Range Power Input" ReqIFText="The power system shall support a wide range of input voltages. Rationale:To use in diverse regions.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="11e67835-78c6-4ea0-ae30-ebc8e50efdc7" source="#c9f1f3cf-185b-4016-a2dd-b2b71050b8ed"
