            </ownedRequirements>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Folder" id="09dde396-8c95-4ba4-b978-df395d5c00d3"
              ReqIFLongName="Communication System">
            <ownedRequirements xsi:type="Requirements:Requirement" id="dd640a56-2832-448a-87d2-e8dde2639126"
                ReqIFName="Communications Levels" ReqIFText="The communications sub-system shall operate on various levels (local, national, regional, international). Rationale:Ensures broad communication capacity.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="1d0b472a-c147-4ffb-9295-6663d935ca36" source="#dd640a56-2832-448a-87d2-e8dde2639126"
