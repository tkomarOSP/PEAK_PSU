            <ownedRequirements xsi:type="Requirements:Requirement" id="9f8e7489-7510-4a8d-a0f9-9b0294c17efc"
                ReqIFName="Leverage Existing Communication Tech" ReqIFText="The communications sub-system shall leverage existing technology. Rationale:To maintain efficiency and practicality.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="f03290bf-6d01-4f95-b032-4238244a3299" source="#9f8e7489-7510-4a8d-a0f9-9b0294c17efc"
