            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="bfbe63f7-9593-4f45-903b-597bbaf5c9f7"
                ReqIFName="Integrate Communications" ReqIFText="The communications system shall integrate with the situational awareness component. Rationale:For streamlined operations.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="920c5b5c-89cf-4177-aa94-db77f7077118" source="#bfbe63f7-9593-4f45-903b-597bbaf5c9f7"
