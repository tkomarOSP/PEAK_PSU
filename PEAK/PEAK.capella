            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="54646119-85af-4a04-8d40-ad28eed7b3e0"
                ReqIFName="Low-Bandwidth Communications" ReqIFText="The communication device shall transmit data over a low-bandwidth network. Rationale:To optimize communication in variable conditions.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="4480a190-d024-4162-a34b-f00feeae3193" source="#54646119-85af-4a04-8d40-ad28eed7b3e0"
