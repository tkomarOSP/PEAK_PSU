    <ownedArchitectures xsi:type="org.polarsys.capella.core.data.ctx:SystemAnalysis"
        id="1469af64-4214-4be5-913c-cadbfd4fcd5b" name="System Analysis">
      <ownedExtensions xsi:type="CapellaRequirements:CapellaModule" id="90645741-3a11-48f2-88a5-c846013b7ae9"
          ReqIFLongName="Customer Requirements" ReqIFName="User Requirements">
        <ownedRequirements xsi:type="Requirements:Requirement" id="5bc632c1-af32-4682-945d-607c3dfe6912"
            ReqIFName="Cargo Pallet Fit" ReqIFText="The system components shall fit on a single 463L cargo air pallet. Rationale:Standardizes military air transport."/>
        <ownedRequirements xsi:type="Requirements:Requirement" id="e034047e-3d6c-4cd3-bfa4-a5e89e7613bf"
            ReqIFName="Water Distribution Capability" ReqIFText="The system shall include water distribution capability. Rationale:To facilitate potable water supply.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="17181b48-84e0-49f6-9c4b-c14b781b7e8e"
              source="#e034047e-3d6c-4cd3-bfa4-a5e89e7613bf" target="#5cf5dba7-972a-486a-87ec-faa124ed3d5d"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="2760202e-ef64-41f4-a9f9-e4a1f63f6bb7"
            ReqIFName="Situational Awareness Features" ReqIFText="The system shall include local situational awareness capabilities. Rationale:To provide essential data to responders.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="6a702541-e527-4af8-9bce-4758b9341935"
              source="#2760202e-ef64-41f4-a9f9-e4a1f63f6bb7" target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="f80f9d03-f3a2-4690-974f-e0bf28470bc6"
            ReqIFName="Integrate Aerial Device" ReqIFText="The system shall include an unmanned aerial system. Rationale:To monitor environments and infrastructure.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="c5c37695-3ce6-4d2d-a290-45f8cc358f60"
              source="#f80f9d03-f3a2-4690-974f-e0bf28470bc6" target="#d7138526-4d27-4545-a98e-84368bc85308"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="0133d8c8-c011-473a-b1d9-810e9a9469d7"
            ReqIFName="Transmit Situation Reports" ReqIFText="The system shall enable transmitting situation reports. Rationale:To keep authorities and aid personnel informed.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="f398aa5d-9b41-4ab4-aac5-9bbc058d6e9c"
              source="#0133d8c8-c011-473a-b1d9-810e9a9469d7" target="#4854d23a-6f56-469d-afa5-7c946debd4a6"/>
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="71141f70-1fb4-4149-8f17-cd07cf4cbcd2"
              source="#0133d8c8-c011-473a-b1d9-810e9a9469d7" target="#b82cda73-10cd-4851-8b5e-d158fe5606b3"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="aa3a5b1f-eeea-4e7f-ac45-42b5bb4da098"
            ReqIFName="Public-Private Data Sharing" ReqIFText="The system shall enable data sharing between public and private sector entities. Rationale:Enhances cooperation and resource use.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="11158926-2016-4acd-a22e-63847da0026f"
              source="#aa3a5b1f-eeea-4e7f-ac45-42b5bb4da098" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="31b239ff-f9b0-4e83-99cc-033d998984e1"
            ReqIFName="Humanitarian Logistics" ReqIFText="The system shall support humanitarian logistics activities. Rationale:Facilitates resource delivery and setup.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="f991eede-d48b-4b28-a84c-fd935c3e9334"
              source="#31b239ff-f9b0-4e83-99cc-033d998984e1" target="#b82cda73-10cd-4851-8b5e-d158fe5606b3"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="477a3dad-47a6-4ecc-8bb7-92223b8a882f"
            ReqIFName="Adapted Tech for Diverse Terrains" ReqIFText="The system shall adapt its technology for various terrains. Rationale:To ensure wide applicability.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="28414c96-ffa0-44cc-b099-d21f6a41bedd"
              source="#477a3dad-47a6-4ecc-8bb7-92223b8a882f" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="ce579235-615c-4713-88ff-d673bb10ec88"
            ReqIFName="Self-Diagnosis and Alerts" ReqIFText="The system shall include self-diagnosis capabilities with alert systems. Rationale:Promotes proactive maintenance.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="0a13247f-a0f8-4570-adb2-95ef8f0165b0"
              source="#ce579235-615c-4713-88ff-d673bb10ec88" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="fdcb1d3b-6c0b-4428-acbd-d924b522a793"
            ReqIFName="Local Partner Training" ReqIFText="The system shall provide training to local partners on operational use. Rationale:Enhances capacity building and sustainability.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="acf5e83d-b29a-4615-b69e-515cf1390337"
              source="#fdcb1d3b-6c0b-4428-acbd-d924b522a793" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="7edf483a-089c-4f46-9470-8635a23bac0b"
            ReqIFName="Synchronized Updates" ReqIFText="The system shall support synchronized updates for all components. Rationale:To ensure consistent operation.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="bc449b31-66b0-40e2-a026-25b6fe5c380e"
              source="#7edf483a-089c-4f46-9470-8635a23bac0b" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="124bbd4d-2926-4cc3-aad4-efe12005063f"
            ReqIFName="Public Information Broadcast" ReqIFText="The system&amp;#x27;s communications capability shall include a public information broadcast channel. Rationale:Raises public awareness in crisis scenarios.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="a0cf74a6-8ef5-4020-be55-626a896b2e5b"
              source="#124bbd4d-2926-4cc3-aad4-efe12005063f" target="#b82cda73-10cd-4851-8b5e-d158fe5606b3"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="0c5a32e9-2763-4f8f-a56c-7f1d2526a29d"
            ReqIFName="Interactive User Guide" ReqIFText="An interactive user guide shall be available through the system. Rationale:Facilitates quick user adaptation.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="f54605b1-988f-4ed3-ac02-bf9419a84476"
              source="#0c5a32e9-2763-4f8f-a56c-7f1d2526a29d" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Requirement" id="b03c6c20-3dc4-416d-8a83-04b31351b16e"
            ReqIFName="Scalable Supply Network" ReqIFText="The system setup shall support a scalable supply network for kit components. Rationale:Ensures responsiveness to demand fluctuations.">
          <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation" id="1e949dd1-c029-4786-84bf-ed2786be8f0d"
              source="#b03c6c20-3dc4-416d-8a83-04b31351b16e" target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
        </ownedRequirements>
        <ownedRequirements xsi:type="Requirements:Folder" id="524ac81c-729f-4026-87f2-f654e217c158"
            ReqIFLongName="System">
          <ownedRequirements xsi:type="Requirements:Requirement" id="f048abf8-026b-427e-bab8-a5b807f53220"
              ReqIFName="Use COTS Technology" ReqIFText="The system shall utilize commercial-off-the-shelf technology. Rationale:Requires limited development and accessible technology."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="727cda0b-9fc7-409a-bbf1-0cabae756b92"
              ReqIFName="Easy Operation" ReqIFText="The system shall be easy to operate. Rationale:To allow various personnel to manage the system."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="c073a16c-7a7c-4417-84a7-3bc86afc54f5"
              ReqIFName="Low Maintenance" ReqIFText="The system shall require low maintenance. Rationale:To reduce operational sustainment costs."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="fd3da4fa-0815-4b65-bbc0-f5ddab20c8c4"
              ReqIFName="Export Capability" ReqIFText="The system shall be exportable to foreign nations. Rationale:For deployment in various geographic regions."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="03b356b5-7b86-419a-bf4c-00e5e323e7da"
              ReqIFName="Non-Proprietary Technology" ReqIFText="The system shall use non-proprietary technology. Rationale:To ensure flexibility and interoperability."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="e5d434b3-c43a-4f79-8148-d2c085f9d265"
              ReqIFName="Lightweight Design" ReqIFText="The system shall be lightweight and man-portable. Rationale:For easy transport and deployment by personnel."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="a55d41b8-0218-4629-992c-aad4706f14d4"
              ReqIFName="Durability" ReqIFText="The system shall be durable and weather resistant. Rationale:To withstand diverse environmental conditions."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="7ee5b285-3ad8-407b-a1af-540cb9045cda"
              ReqIFName="Limited HAZMAT Needs" ReqIFText="The system shall have limited HAZMAT requirements. Rationale:To reduce risks associated with hazardous materials."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="61e43109-2c0b-4b5d-a820-1ab76f1f4e2b"
              ReqIFName="Transportable System" ReqIFText="The system shall be transportable by air, sea, and land modes. Rationale:To ensure flexible logistics."/>
          <ownedRequirements xsi:type="Requirements:Requirement" id="7f60976c-7ba9-4f67-ba42-29dab5c40f61"
              ReqIFName="Resilience Against Natural Disasters" ReqIFText="The system shall be resilient against natural disaster conditions. Rationale:Ensures reliable functionality under stress.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="ff81b749-440c-44a1-9586-62ae6e7b071a" source="#7f60976c-7ba9-4f67-ba42-29dab5c40f61"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="9d517a84-4466-423c-9761-335acdbab0e4"
              ReqIFName="Rapid Deployment" ReqIFText="The system shall be capable of rapid deployment. Rationale:To ensure timely delivery of services.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="ceaab845-9c81-4424-b1fc-107881cb97d2" source="#9d517a84-4466-423c-9761-335acdbab0e4"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="8fd556c3-7272-4286-9dc7-468cefd64a69"
              ReqIFName="Modular Components" ReqIFText="The system shall include modular components for easy replacement or upgrade. Rationale:To maintain and extend service life of the system.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="227c9a80-fe04-4972-8793-e4b03185cf5b" source="#8fd556c3-7272-4286-9dc7-468cefd64a69"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="2d525c10-bc76-4d13-b906-9e8cf8acc76e"
              ReqIFName="Secure Communications" ReqIFText="The system shall provide secure voice and data communications. Rationale:To ensure confidentiality and integrity of information.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="b3ec316e-37db-4bab-9a9d-655d4e06993f" source="#2d525c10-bc76-4d13-b906-9e8cf8acc76e"
                target="#422f3fea-da3c-48a7-9f26-d1321ddfc404"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="dc412dd7-1365-4a47-a063-9f325e3fd13e"
              ReqIFName="Localized Training Programs" ReqIFText="The system shall include programs for localized training. Rationale:Ensures applicable skills in diverse deployment regions.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="d9c4a711-4830-4a23-8926-af10f242ae79" source="#dc412dd7-1365-4a47-a063-9f325e3fd13e"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="34712745-fd0b-43ac-b6a2-152e8232355a"
              ReqIFName="Autonomous Operation Capability" ReqIFText="The system shall have capabilities for semi-autonomous operation. Rationale:Reduces operator demand in high-stress situations.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="f5389f60-033b-4c7a-96df-d91120dc5115" source="#34712745-fd0b-43ac-b6a2-152e8232355a"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="a9e3d169-6a02-4131-b8ba-635570386f0c"
              ReqIFName="Scalable Design" ReqIFText="The system shall have a scalable design to fit varied operational needs. Rationale:Allows flexible response sizing.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="4be73ab5-20b4-4ef3-be64-b3135eba10ec" source="#a9e3d169-6a02-4131-b8ba-635570386f0c"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="ec76c685-d6b2-4b68-a6f5-488266ed57bd"
              ReqIFName="Interoperability Standard Compliance" ReqIFText="The system shall comply with relevant interoperability standards. Rationale:To ensure broad compatibility.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="15ba8e4d-3ffe-4d50-92ed-5ba3e8ed8c4b" source="#ec76c685-d6b2-4b68-a6f5-488266ed57bd"
                target="#ddc7faf6-4ef7-4adb-9c7b-8a55f0958947"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Requirement" id="5ee1bcb0-10e1-4cf3-9be1-48124de00939"
              ReqIFName="Data Logging" ReqIFText="The system shall log operational data for post-operation analysis. Rationale:Enhances review and optimization capacity.">
            <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                id="a589a3c5-3e75-410a-a299-8f13fbca178f" source="#5ee1bcb0-10e1-4cf3-9be1-48124de00939"
