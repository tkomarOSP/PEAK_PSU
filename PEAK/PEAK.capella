      <ownedExtensions xsi:type="CapellaRequirements:CapellaModule" id="22b1a292-d69c-4344-8aac-3eab3a5eac4b"
          ReqIFLongName="Water Subsytem Requirement">
        <ownedRequirements xsi:type="Requirements:Requirement" id="5e970ea1-fce2-4706-bcae-2920cab7d7e2"
            ReqIFText="&lt;p>The entire water system that is composed of:&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>Environment Water Pump&lt;/li>&#xA;&#x9;&lt;li>Environment water Tank&lt;/li>&#xA;&#x9;&lt;li>Ultrafiltration Filter&lt;/li>&#xA;&#x9;&lt;li>Carbon Filter&lt;/li>&#xA;&#x9;&lt;li>Clean water Storage Tanks&lt;/li>&#xA;&#x9;&lt;li>Facets&lt;/li>&#xA;&#x9;&lt;li>Buckets&lt;/li>&#xA;&lt;/ul>&#xA;&#xA;&lt;p>Shall fit within a space with the&amp;nbsp;given the dimensions.&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>Width =&amp;nbsp;8 foot&lt;/li>&#xA;&#x9;&lt;li>Length = 8 foot&lt;/li>&#xA;&#x9;&lt;li>Height = 4 foot&lt;/li>&#xA;&#x9;&lt;li>8*8*4 = 256 cubic foot&lt;/li>&#xA;&lt;/ul>&#xA;&#xA;&lt;p>&amp;nbsp;&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>&amp;nbsp;&lt;/li>&#xA;&lt;/ul>&#xA;">
          <ownedRelations xsi:type="Requirements:InternalRelation" id="833e90dc-1eb9-43ac-84ca-ef6764acd28f"
              source="#5e970ea1-fce2-4706-bcae-2920cab7d7e2" target="#ed3ccdb6-99b2-48fb-baba-956f0afd17df"/>
