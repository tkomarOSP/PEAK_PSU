    <ownedArchitectures xsi:type="org.polarsys.capella.core.data.la:LogicalArchitecture"
        id="064ccf8d-7e79-4fc5-a0f2-74bf2980472d" name="Logical Architecture">
      <ownedExtensions xsi:type="CapellaRequirements:CapellaModule" id="ead5dfb3-aa0d-4745-bc8f-f464f8f8312b"
          ReqIFLongName="System Requirements" ReqIFName="System Requirements">
        <ownedRequirements xsi:type="Requirements:Folder" id="b1d52b3e-d261-428f-8cbe-a72bde29dd46"
            ReqIFLongName="System">
          <ownedRequirements xsi:type="Requirements:Folder" id="9e55c8fc-ceac-4b54-9c60-b0f59a971789"
              ReqIFLongName="Water Purification">
            <ownedRequirements xsi:type="Requirements:Folder" id="44b58ab1-8d08-4ef1-9b7f-c3d949756384"
                ReqIFName="Storage Container">
              <ownedRequirements xsi:type="Requirements:Requirement" id="8590ba82-13eb-4668-af7c-e5715db777d8"
                  ReqIFName="Size" ReqIFText="&lt;p>The storage container shall be capable of containing at least&amp;nbsp;1000 liters of water.&lt;/p>&#xA;">
                <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                    id="fe329b6f-e8f8-4ed8-b688-1fd1894d04f3" source="#8590ba82-13eb-4668-af7c-e5715db777d8"
                    target="#8b1dc6a0-6a65-4b32-b1a9-60e2e39377b1"/>
                <ownedRelations xsi:type="Requirements:InternalRelation" id="2f7316fc-f29f-4651-b288-ced8e5e533f8"
                    source="#8590ba82-13eb-4668-af7c-e5715db777d8" target="#7546d353-e92f-4f5e-9fd2-0d4aef285e80"/>
                <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                    id="55916bed-3642-4d42-9634-946d25cd537a" source="#8590ba82-13eb-4668-af7c-e5715db777d8"
                    target="#0ddc8347-bd7c-4967-ba87-d7c508e779d6"/>
              </ownedRequirements>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="ed3ccdb6-99b2-48fb-baba-956f0afd17df"
                ReqIFLongName="Volume" ReqIFText="&lt;p>The system shall meet the following requirement.&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>Volume Requirement: 49% of the total PEAK volume&lt;/li>&#xA;&#x9;&lt;li>Volume = 0.49 x 529.36 = &lt;span style=&quot;color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>259.39 cubic feet&lt;/span>&lt;/li>&#xA;&lt;/ul>&#xA;">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="1d53d521-5c3d-4d35-8b93-64263c3d92ce" source="#ed3ccdb6-99b2-48fb-baba-956f0afd17df"
                  target="#cfa71969-133d-4e0e-9115-594e582b5cff"/>
              <ownedRelations xsi:type="Requirements:InternalRelation" id="c9ab30ff-1851-4d43-80f4-189d0ff4f00c"
                  source="#ed3ccdb6-99b2-48fb-baba-956f0afd17df" target="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Folder" id="618effbc-8639-4cc8-a15e-115f09079dfb"
                ReqIFLongName="Water Storage">
              <ownedRequirements xsi:type="Requirements:Folder" id="9decc83f-847f-4017-b05d-16a5f95c9b67"
                  ReqIFLongName="Faucets">
                <ownedRequirements xsi:type="Requirements:Requirement" id="61e425b0-6e7b-4bb0-af4b-791e9356ffcf"
                    ReqIFLongName="Water Dispense" ReqIFText="&lt;p>&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>The system shall ensure that the faucets are capable of dispensing a total of 444 liters of water over an 8-hour period. This requirement ensures that the water distribution system can meet the daily consumption needs of all users efficiently and effectively.&lt;/span>&lt;/p>&#xA;">
                  <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                      id="6751dede-2876-4088-a408-5625362635dc" source="#61e425b0-6e7b-4bb0-af4b-791e9356ffcf"
                      target="#c32ed5fd-734f-432c-851d-93cc677dc51a"/>
                  <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                      id="69e98620-b6e5-469d-b9b3-ec89a6bb71d8" source="#61e425b0-6e7b-4bb0-af4b-791e9356ffcf"
                      target="#c9d3d316-e7c5-4bdc-9aac-722ddb6b0746"/>
                </ownedRequirements>
              </ownedRequirements>
            </ownedRequirements>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Folder" id="eb51cc88-aee4-4821-9252-b038d067e8ea"
              ReqIFLongName="Situational Awareness">
            <ownedRequirements xsi:type="Requirements:Requirement" id="c54576db-c1d3-40f9-9d8e-f2b650588b9e"
                ReqIFName="Include Camera System" ReqIFText="The situational awareness component shall include a camera system. Rationale:To capture essential visual data.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="79fe7b23-15de-4c92-8f2b-59169ce1d632" source="#c54576db-c1d3-40f9-9d8e-f2b650588b9e"
                  target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="9ba59d96-c88d-4415-b52a-9ee88b97b2eb"
                ReqIFName="Integrate Situational Platform" ReqIFText="The situational awareness component shall have an integrated platform. Rationale:To provide a cohesive data framework.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="77a375ec-7b08-4206-a060-ccb51e9e0351" source="#9ba59d96-c88d-4415-b52a-9ee88b97b2eb"
                  target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="7c430d3f-48da-41e7-8b68-07005030e578"
                ReqIFName="Power Through Kit" ReqIFText="The situational awareness system shall be powered through the kit. Rationale:Ensures system autonomy.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="01f11e7c-1ea2-4d56-99f8-c09453f44697" source="#7c430d3f-48da-41e7-8b68-07005030e578"
                  target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="da5cbe0d-f69c-475b-8e48-c3b2c44cf015"
                ReqIFName="Existing Awareness Tech" ReqIFText="The situational awareness system shall leverage existing technology. Rationale:To optimize existing capabilities.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="1f0eceb4-5868-4403-82b3-9acb39f541cb" source="#da5cbe0d-f69c-475b-8e48-c3b2c44cf015"
                  target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="15d631e5-338d-4180-aeec-ba05486d0956"
                ReqIFName="GIS Integration" ReqIFText="Situational awareness tools shall integrate with Geographic Information Systems (GIS). Rationale:To enhance mapping and tracking capabilities.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="1187e5e7-92eb-489d-ab09-f585577d079c" source="#15d631e5-338d-4180-aeec-ba05486d0956"
                  target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="71ecaf6b-fdfc-441d-9f9f-cdf003091d33"
                ReqIFName="Weather Forecast Alerts" ReqIFText="Situational awareness components shall issue alerts based on forecasted weather conditions. Rationale:Prepares users for imminent conditions.">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="02bd03b3-5fc8-4ce7-9684-893534273e73" source="#71ecaf6b-fdfc-441d-9f9f-cdf003091d33"
                  target="#c19d4576-93a1-45ad-8f03-de36a56f0ea3"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="73965b4b-9f1e-49c3-a9a6-3da3dafb165e"
                ReqIFLongName="Volume" ReqIFName="Volume" ReqIFText="&lt;p>The situational awareness&amp;nbsp;subsystem shall achieve equal or less than the following volume:&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>Volume Requirement: 19% of the total PEAK volume&lt;/li>&#xA;&#x9;&lt;li>Volume = 0.09 x 529.36 = &lt;span style=&quot;color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>47.65 cubic feet&lt;/span>&lt;/li>&#xA;&lt;/ul>&#xA;">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="38018413-ac88-4024-a976-b6a1a634f28a" source="#73965b4b-9f1e-49c3-a9a6-3da3dafb165e"
                  target="#36564c6f-d7ce-44f4-bd8b-a4dfd90237eb"/>
              <ownedRelations xsi:type="Requirements:InternalRelation" id="150cc79e-d37e-4ba9-b96c-297bd21e6740"
                  source="#73965b4b-9f1e-49c3-a9a6-3da3dafb165e" target="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"/>
            </ownedRequirements>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Folder" id="2a004731-4971-433e-8533-f3c178881adc"
              ReqIFLongName="Packaging Requirements">
            <ownedRequirements xsi:type="Requirements:Requirement" id="4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"
                ReqIFLongName="Dimensions" ReqIFText="&lt;p>The system shall conform to the following dimensional constraints to ensure compatibility with standard transport and storage solutions:&lt;/p>&#xA;&#xA;&lt;p>&lt;strong style=&quot;font-weight: bold;&quot;>Dimensions:&lt;/strong>&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>&lt;strong style=&quot;font-weight: bold;&quot;>Length: 108 inches (274.32 cm)&lt;/strong>&lt;/li>&#xA;&#x9;&lt;li>&lt;strong style=&quot;font-weight: bold;&quot;>Width: 88 inches (223.52 cm)&lt;/strong>&lt;/li>&#xA;&#x9;&lt;li>&lt;strong style=&quot;font-weight: bold;&quot;>Height: Up to 96 inches (243.84 cm)&lt;/strong>&lt;/li>&#xA;&lt;/ul>&#xA;&#xA;&lt;p>Volume ::&lt;/p>&#xA;&#xA;&lt;p>&lt;span style=&quot;text-align: left; color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>The volume of the system is approximately 529.36 cubic feet or 14.992.73 cubic liters.&lt;/span>&lt;/p>&#xA;&#xA;&lt;p>&amp;nbsp;&lt;/p>&#xA;&#xA;&lt;p>&amp;nbsp;&lt;/p>&#xA;&#xA;&lt;p>&amp;nbsp;&lt;/p>&#xA;">
              <ownedRelations xsi:type="Requirements:InternalRelation" id="b29947d5-d79a-4629-a43a-c3c593772699"
                  source="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2" target="#5bc632c1-af32-4682-945d-607c3dfe6912"/>
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="1f5b2ae4-98f1-4c40-89c5-8d8a675354fc" source="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"
                  target="#c34a0831-0674-48f4-ab45-15e732e5e13b"/>
            </ownedRequirements>
            <ownedRequirements xsi:type="Requirements:Requirement" id="7d7260e1-446b-43a9-825e-0287cbb8a095"
                ReqIFLongName="Volume" ReqIFText="&lt;p>The packaging for the kit shall be equal or less than a volume of &lt;span style=&quot;text-align: left; color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>4% of the total PEAK volume, which is 0.04 x 529.36 = 21.17 cubic feet.&lt;/span>&lt;/p>&#xA;">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="17ec7eb6-4561-4806-b1f2-d49e4682bd54" source="#7d7260e1-446b-43a9-825e-0287cbb8a095"
                  target="#7762e040-2c1d-4a5f-a5d0-7fcb89d2672b"/>
              <ownedRelations xsi:type="Requirements:InternalRelation" id="178954dd-de28-4fd6-a66d-90fac32bd333"
                  source="#7d7260e1-446b-43a9-825e-0287cbb8a095" target="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"/>
            </ownedRequirements>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Folder" id="6a37ce37-c369-41e2-95cb-9d316716c907"
              ReqIFLongName="Power Subsystem">
            <ownedRequirements xsi:type="Requirements:Requirement" id="256e6c3c-74a7-437f-8e0a-a68bdfbd7548"
                ReqIFLongName="Volume" ReqIFText="&lt;p>The Power Subsystem shall less or equal to the following volume:&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>Volume Requirement: 19% of the total PEAK volume&lt;/li>&#xA;&#x9;&lt;li>Volume = 0.19 x 529.36 = &lt;span style=&quot;color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>100.58 cubic feet&lt;/span>&lt;/li>&#xA;&lt;/ul>&#xA;">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="723bc079-ea1a-46b6-b305-d59b3223b248" source="#256e6c3c-74a7-437f-8e0a-a68bdfbd7548"
                  target="#96da9729-25c3-424a-ae4b-802fc88abdad"/>
              <ownedRelations xsi:type="Requirements:InternalRelation" id="6db6ae78-7f27-4fd2-b738-9f4f13c0b4eb"
                  source="#256e6c3c-74a7-437f-8e0a-a68bdfbd7548" target="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"/>
            </ownedRequirements>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Folder" id="7e050981-923f-4fc4-97f9-a05b6948c719"
              ReqIFLongName="Communication Subsystem">
            <ownedRequirements xsi:type="Requirements:Requirement" id="3a02e110-8ff6-415b-8f59-4d955e697feb"
                ReqIFLongName="Volume"/>
          </ownedRequirements>
          <ownedRequirements xsi:type="Requirements:Folder" id="71dfe6b9-fb32-486c-b9a0-4a45a1842df0"
              ReqIFLongName="Communication">
            <ownedRequirements xsi:type="Requirements:Requirement" id="b425c869-4eb9-4f89-aa8e-aff4bcc3fb94"
                ReqIFLongName="Volume" ReqIFText="&lt;p>The communication subsystem shall achieve equal or less than the following volume:&lt;/p>&#xA;&#xA;&lt;ul>&#xA;&#x9;&lt;li>Volume Requirement: 29% of the total PEAK volume&lt;/li>&#xA;&#x9;&lt;li>Volume = 0.19 x 529.36 = &lt;span style=&quot;color: rgb(0, 0, 0); text-transform: none; text-indent: 0px; letter-spacing: normal; font-family: system-ui, -apple-system, blinkmacsystemfont, &amp;quot;Segoe UI&amp;quot;, helvetica, arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; font-size: 14px; font-style: normal; font-weight: 400; word-spacing: 0px; float: none; display: inline !important; white-space: normal; orphans: 2; widows: 2; background-color: rgb(255, 255, 255); font-variant-ligatures: normal; font-variant-caps: normal; -webkit-text-stroke-width: 0px; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;>100.58 cubic feet&lt;/span>&lt;/li>&#xA;&lt;/ul>&#xA;">
              <ownedRelations xsi:type="CapellaRequirements:CapellaIncomingRelation"
                  id="c8bbc58d-67e7-428a-85cf-a80b315e6ab4" source="#b425c869-4eb9-4f89-aa8e-aff4bcc3fb94"
                  target="#e51003f0-ef85-4e34-8862-c7ebcf8109d3"/>
              <ownedRelations xsi:type="Requirements:InternalRelation" id="d3edca9c-1e5e-40fe-bcef-9856ae4b5c69"
                  source="#b425c869-4eb9-4f89-aa8e-aff4bcc3fb94" target="#4b5d7cfd-2e41-4a75-b2d5-1682c6ad4ca2"/>
            </ownedRequirements>
          </ownedRequirements>
        </ownedRequirements>
      </ownedExtensions>
